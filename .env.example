# Copy this file to .env before deploying on the Linux server.

# Runtime launcher settings used by start.sh / stop.sh / status.sh
PROTEIN_BINDER_AGENT_RUNTIME_PYTHON=python3
PROTEIN_BINDER_AGENT_CONFIG=protein_agent/config/agent_config.yaml
PROTEIN_BINDER_AGENT_PID_FILE=./protein-binder-agent.pid
PROTEIN_BINDER_AGENT_LOG_DIR=./logs

# OpenAI-compatible LLM settings.
# These aliases are intentionally the same pattern used by esm3-agent.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5.2

# Optional explicit aliases for this repo.
PROTEIN_BINDER_AGENT_OPENAI_API_KEY=
PROTEIN_BINDER_AGENT_OPENAI_BASE_URL=
PROTEIN_BINDER_AGENT_LLM_MODEL=

# API service settings
PROTEIN_BINDER_AGENT_API_HOST=0.0.0.0
PROTEIN_BINDER_AGENT_API_PORT=8200
PROTEIN_BINDER_AGENT_REQUEST_TIMEOUT=300

# Data/output locations
PROTEIN_BINDER_AGENT_DATA_DIR=./data
PROTEIN_BINDER_AGENT_RESULT_DIR=./data/results
PROTEIN_BINDER_AGENT_ANALYSIS_DIR=./data/analysis
PROTEIN_BINDER_AGENT_UPLOAD_DIR=./data/uploads

# Default workflow profile: balanced / complexa_only / bindcraft_only
PROTEIN_BINDER_AGENT_DEFAULT_WORKFLOW=balanced

# Default chain assumptions for generated complexes
PROTEIN_BINDER_AGENT_DEFAULT_TARGET_CHAIN=A
PROTEIN_BINDER_AGENT_DEFAULT_BINDER_CHAIN=B

# BindCraft server path
PROTEIN_BINDER_AGENT_BINDCRAFT_DIR=/mnt/disk3/tio_nekton4/BindCraft/
PROTEIN_BINDER_AGENT_BINDCRAFT_PYTHON=python
PROTEIN_BINDER_AGENT_BINDCRAFT_SETTINGS_DIR=
PROTEIN_BINDER_AGENT_BINDCRAFT_FILTERS=
PROTEIN_BINDER_AGENT_BINDCRAFT_ADVANCED=
PROTEIN_BINDER_AGENT_BINDCRAFT_TIMEOUT=10800
PROTEIN_BINDER_AGENT_BINDCRAFT_DEFAULT_LENGTH=80
PROTEIN_BINDER_AGENT_BINDCRAFT_DEFAULT_NUM_DESIGNS=10

# Proteina-Complexa server path and checkpoints
PROTEIN_BINDER_AGENT_COMPLEXA_DIR=/mnt/disk3/tio_nekton4/Proteina-Complexa/
PROTEIN_BINDER_AGENT_COMPLEXA_CLI=complexa
PROTEIN_BINDER_AGENT_COMPLEXA_PYTHON=
PROTEIN_BINDER_AGENT_COMPLEXA_CONFIG_DIR=
PROTEIN_BINDER_AGENT_COMPLEXA_CKPT_PATH=/mnt/disk3/tio_nekton4/Proteina-Complexa/Protein-Target-160M-v1/
PROTEIN_BINDER_AGENT_COMPLEXA_CKPT_NAME=complexa.ckpt
PROTEIN_BINDER_AGENT_COMPLEXA_AUTOENCODER_CKPT_PATH=/mnt/disk3/tio_nekton4/Proteina-Complexa/Protein-Target-160M-v1/complexa_ae.ckpt
PROTEIN_BINDER_AGENT_COMPLEXA_DEFAULT_PIPELINE=binder
PROTEIN_BINDER_AGENT_COMPLEXA_GEN_NJOBS=1
PROTEIN_BINDER_AGENT_COMPLEXA_EVAL_NJOBS=1
PROTEIN_BINDER_AGENT_COMPLEXA_TIMEOUT=7200
PROTEIN_BINDER_AGENT_COMPLEXA_VALIDATE=true

# MDAnalysis defaults
PROTEIN_BINDER_AGENT_MDANALYSIS_CUTOFF=5.0
PROTEIN_BINDER_AGENT_MDANALYSIS_DEFAULT=full_report
